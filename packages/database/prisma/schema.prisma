generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  FREE
  PRO
  TEAM
}

enum Provider {
  CLAUDE
  OPENAI
  GEMINI
  OLLAMA
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  email     String?  @unique
  username  String?
  avatarUrl String?
  tier      Tier     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installations Installation[]
  apiKeys       ApiKey[]
  subscription  Subscription?

  @@map("users")
}

model Installation {
  id                   String   @id @default(cuid())
  userId               String
  githubInstallationId String   @unique
  accountLogin         String
  repoIds              String[]
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([userId])
  @@map("installations")
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     Provider
  encryptedKey String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("api_keys")
}

model Review {
  id             String   @id @default(cuid())
  installationId String
  prNumber       Int
  repoName       String
  issues         Json
  summary        String
  score          Int
  createdAt      DateTime @default(now())

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([repoName, prNumber])
  @@map("reviews")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  stripeId  String             @unique
  tier      Tier               @default(PRO)
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
